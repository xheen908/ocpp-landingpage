<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/coin-icon.png">
    <title><%= t.metaTitle %></title>
    <meta name="description" content="<%= t.metaDesc %>">
    
    <!-- SEO: Canonical and Hreflang Clusters (Global AI Indexing) -->
    <link rel="canonical" href="https://V-Ledger.com/<%= t.lang %>/">
    <!-- Hreflang Clusters (Global AI Indexing) -->
    <link rel="alternate" hreflang="de-de" href="https://V-Ledger.com/de-de/">
    <link rel="alternate" hreflang="en-us" href="https://V-Ledger.com/en-us/">
    <link rel="alternate" hreflang="es-es" href="https://V-Ledger.com/es-es/">
    <link rel="alternate" hreflang="vi-vn" href="https://V-Ledger.com/vi-vn/">
    <link rel="alternate" hreflang="th-th" href="https://V-Ledger.com/th-th/">
    <link rel="alternate" hreflang="ja-jp" href="https://V-Ledger.com/ja-jp/">
    <link rel="alternate" hreflang="ko-kr" href="https://V-Ledger.com/ko-kr/">
    <link rel="alternate" hreflang="hi-in" href="https://V-Ledger.com/hi-in/">
    <link rel="alternate" hreflang="bn-bd" href="https://V-Ledger.com/bn-bd/">
    <link rel="alternate" hreflang="zh-cn" href="https://V-Ledger.com/zh-cn/">
    <link rel="alternate" hreflang="zh-tw" href="https://V-Ledger.com/zh-tw/">
    <link rel="alternate" hreflang="x-default" href="https://V-Ledger.com/en-us/">

    <!-- Social Preview: Open Graph (LinkedIn/Meta) -->
    <meta property="og:title" content="<%= t.metaTitle %>">
    <meta property="og:description" content="<%= t.metaDesc %>">
    <meta property="og:image" content="https://V-Ledger.com/assets/hero-elite.png">
    <meta property="og:url" content="https://V-Ledger.com/<%= t.lang %>/">
    <meta property="og:type" content="website">

    <!-- Social Preview: Twitter/X -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= t.metaTitle %>">
    <meta name="twitter:description" content="<%= t.metaDesc %>">
    <meta name="twitter:image" content="https://V-Ledger.com/assets/hero-elite.png">

    <!-- JSON-LD Structured Data (Machine Readability & AI Agents) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://V-Ledger.com/#organization",
          "name": "V-LEDGER",
          "url": "https://V-Ledger.com",
          "logo": "https://V-Ledger.com/assets/logo.png",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Albertstr. 7",
            "postalCode": "47059",
            "addressLocality": "Duisburg",
            "addressCountry": "DE"
          }
        },
        {
          "@type": "LocalBusiness",
          "name": "V-LEDGER",
          "image": "https://V-Ledger.com/assets/hero-elite.png",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Albertstr. 7",
            "postalCode": "47059",
            "addressLocality": "Duisburg",
            "addressRegion": "NRW",
            "addressCountry": "DE"
          },
          "description": "Gateway for European ESPR 2027 Compliance at Port of Duisburg.",
          "url": "https://V-Ledger.com"
        },
        {
          "@type": "TechArticle",
          "headline": "V-Ledger: Die Zukunft der ESPR-Compliance (DPP)",
          "description": "<%= t.metaDesc %>",
          "author": { "@id": "https://V-Ledger.com/#organization" },
          "keywords": ["Digital Product Passport", "ESPR 2027", "Battery Passport", "Textiles Compliance", "Duisburg Gateway", "Base L2 Blockchain"]
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            <% t.faqs.forEach((faq, index) => { %>
            {
              "@type": "Question",
              "name": "<%= faq.q %>",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "<%= faq.a %>"
              }
            }<%= index < t.faqs.length - 1 ? ',' : '' %>
            <% }); %>
          ]
        }
      ]
    }
    </script>

    <!-- External Resources -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <link rel="stylesheet" href="/css/style.css?v=13.3-SSR">

    <!-- SES-Proof Scripts (Programmatic Only) -->
    <script src="/js/main.js?v=16.5-CIRCULAR" defer></script>
</head>
<body class="selection:bg-white/10">
    <div class="mesh-bg"></div>

    <%- include('partials/header', { t }) %>

    <main class="max-w-7xl mx-auto px-6 py-20 md:py-40">
        <!-- Hero Section: Build 9.0 Immersive -->
        <div class="grid lg:grid-cols-2 gap-20 items-center mb-12">
            <div class="text-left animate-fade-in relative z-10">
                <div class="absolute -top-20 -left-20 w-64 h-64 bg-[#a88c5a]/10 blur-[120px] rounded-full pointer-events-none"></div>
                <div id="hero-badge" class="badge-market !mb-6"><%= t.badge %></div>
                <h1 id="h1-text" class="text-4xl md:text-5xl font-black mb-10 leading-tight tracking-tight uppercase whitespace-pre-line">
                    <span class="gradient-text"><%- t.h1 %></span>
                </h1>
                <p id="sub-text" class="text-xl md:text-2xl text-white/40 max-w-xl mb-12 font-medium leading-relaxed">
                    <%= t.sub %>
                </p>
                
                <div class="flex flex-wrap gap-8 items-center">
                    <button id="v2-hero-trigger" class="pill-btn pill-btn-vault px-12 py-5 text-xs uppercase tracking-[0.3em] font-black group">
                        <span class="relative z-10"><%= t.cta %></span>
                        <div class="btn-slide"></div>
                    </button>
                    <div class="flex items-center gap-4 px-6 py-3 rounded-2xl border border-white/5 bg-white/2 backdrop-blur-md">
                        <div class="flex -space-x-2">
                            <div class="w-6 h-6 rounded-full bg-[#a88c5a] border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">E</div>
                            <div class="w-6 h-6 rounded-full bg-white border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">S</div>
                            <div class="w-6 h-6 rounded-full bg-[#a88c5a] border-2 border-black flex items-center justify-center text-[10px] font-bold text-black italic">P</div>
                        </div>
                        <span class="text-[10px] font-black tracking-widest text-white/60 uppercase">ESPR 2027 Compliance Standard ready</span>
                    </div>
                </div>
            </div>
            
            <div class="relative group animate-float">
                <!-- Made in Germany Trust Badge -->
                <div class="absolute -top-10 -right-10 z-20 apple-glass-dark px-5 py-2 rounded-[2rem] border border-white/20 shadow-2xl flex items-center gap-4 hover:scale-105 transition-transform duration-500 cursor-default backdrop-blur-3xl group-hover:border-[#a88c5a]/50">
                    <div class="w-16 h-16 rounded-full overflow-hidden shrink-0 shadow-lg border border-white/10 flex items-center justify-center">
                        <img src="/assets/german-seal.png" alt="Made in Germany" class="w-full h-full object-cover scale-150">
                    </div>
                    <div class="flex flex-col">
                        <span class="text-[8px] font-black tracking-[0.2em] text-[#a88c5a] uppercase">Trust Standard</span>
                        <span class="text-xs font-bold text-white/90 whitespace-nowrap"><%= t.madeInGermany %></span>
                    </div>
                </div>

                <div class="absolute -inset-10 bg-gradient-to-tr from-[#a88c5a]/20 to-transparent blur-[100px] opacity-40 group-hover:opacity-60 transition-opacity duration-1000"></div>
                <div class="relative apple-glass rounded-[4rem] overflow-hidden border border-white/10 shadow-[0_0_100px_rgba(0,0,0,0.8)]">
                    <img src="/assets/hero-elite.png" alt="High-Value Goods at Harbor" class="w-full aspect-[4/5] object-cover mix-blend-lighten opacity-95 transition-transform duration-1000 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                    <div class="absolute bottom-10 left-10 right-10 p-8 apple-glass-dark rounded-[2rem] border-white/10 backdrop-blur-3xl transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                        <div class="flex items-center gap-4 mb-3">
                            <div class="w-2 h-2 rounded-full bg-[#a88c5a] animate-pulse"></div>
                            <div class="text-[10px] font-black tracking-[0.3em] uppercase text-[#a88c5a]">Asset Status: Blocked</div>
                        </div>
                        <div class="text-lg font-bold text-white/90 leading-tight">Securing Batteries, Textiles & Luxury Exports against EU Customs barriers.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tech Authority Bar: Build 9.0 Minimalist -->
        <div class="flex flex-wrap justify-between items-center gap-10 mb-6 py-5 border-y border-white/5 opacity-50 hover:opacity-100 transition-all duration-1000 bg-gradient-to-x from-transparent via-white/[0.02] to-transparent">
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6" y2="6"></line><line x1="6" y1="18" x2="6" y2="18"></line></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">Base L2 Infrastructure</span>
            </div>
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">NXP Secure Identity</span>
            </div>
            <div class="flex items-center gap-4 group">
                <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-colors">
                    <svg class="text-white/40 group-hover:text-[#a88c5a]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                </div>
                <span class="text-[11px] font-black tracking-[0.3em] uppercase">ERC-4337 Full Abstraction</span>
            </div>
        </div>

        <!-- Trust & Social Proof: B2B Integration Ecosystem (Build 9.0 Premium) -->
        <div class="my-24 text-center">
            <span class="text-[9px] font-black tracking-[0.4em] text-white/30 uppercase block mb-8">Compatible with Enterprise Architectures</span>
            <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-8 opacity-40 hover:opacity-85 transition-opacity duration-700">
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">SECURE NFC HARDWARE</span>
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">DECENTRALIZED L2 LEDGERS</span>
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">ENTERPRISE ERP SYSTEMS</span>
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">AUTOMOTIVE BATTERY STANDARDS</span>
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">GLOBAL SUPPLY LOGISTICS</span>
                <span class="text-xs font-black tracking-widest text-white uppercase hover:text-[#a88c5a] transition-colors cursor-default">CIRCULAR RECYCLING SCHEMAS</span>
            </div>
        </div>

        <!-- High-Impact Live Network Metrics Grid -->
        <div class="grid md:grid-cols-3 gap-8 my-24 max-w-6xl mx-auto">
            <div class="apple-glass rounded-3xl p-8 border border-white/5 bg-gradient-to-tr from-white/[0.01] to-transparent hover:border-[#a88c5a]/20 transition-all duration-500">
                <div class="text-[#a88c5a] text-3xl md:text-4xl font-black mb-2 tracking-tight">&lt; 800ms</div>
                <div class="text-[10px] font-black tracking-widest text-white/50 uppercase mb-2">Block Finalization Speed</div>
                <p class="text-white/30 text-xs font-medium">Real-time ledger state updates for high-throughput global logistics chains.</p>
            </div>
            <div class="apple-glass rounded-3xl p-8 border border-white/5 bg-gradient-to-tr from-white/[0.01] to-transparent hover:border-[#a88c5a]/20 transition-all duration-500">
                <div class="text-white text-3xl md:text-4xl font-black mb-2 tracking-tight">AES-128 SUN</div>
                <div class="text-[10px] font-black tracking-widest text-white/50 uppercase mb-2">Hardware-Backed Security</div>
                <p class="text-white/30 text-xs font-medium">NXP secure element silicon generating rolling CMAC signatures on scan.</p>
            </div>
            <div class="apple-glass rounded-3xl p-8 border border-white/5 bg-gradient-to-tr from-white/[0.01] to-transparent hover:border-[#a88c5a]/20 transition-all duration-500">
                <div class="text-[#a88c5a] text-3xl md:text-4xl font-black mb-2 tracking-tight">100% ESPR</div>
                <div class="text-[10px] font-black tracking-widest text-white/50 uppercase mb-2">Compliance Architecture</div>
                <p class="text-white/30 text-xs font-medium">Fully matching W3C Verifiable Credentials and Asset Administration Shell standards.</p>
            </div>
        </div>

        <!-- Interactive DPP Live Simulator Section (Build 25.0 - Enterprise Standard) -->
        <section class="my-32 reveal-on-scroll relative">
            <div class="absolute -right-40 top-1/2 -translate-y-1/2 w-96 h-96 bg-[#a88c5a]/5 blur-[150px] rounded-full pointer-events-none"></div>
            
            <div class="text-center max-w-3xl mx-auto mb-16">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-4 animate-pulse">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"></span>
                    </span>
                    Live Technology Showcase
                </div>
                <h2 class="text-3xl md:text-5xl font-black tracking-tight uppercase mb-4 text-white">
                    <%= t.demoTitle || 'Interactive DPP Sandbox' %>
                </h2>
                <p class="text-white/40 text-sm md:text-base font-medium max-w-xl mx-auto leading-relaxed">
                    <%= t.demoDesc || 'Select a category & simulate an NXP secure element scan to compile on-chain Verifiable Credentials and Asset Administration Shell (AAS) submodels instantly.' %>
                </p>
            </div>

            <div class="grid lg:grid-cols-12 gap-8 items-stretch max-w-6xl mx-auto">
                <!-- Left Control Panel -->
                <div class="lg:col-span-5 flex flex-col justify-between apple-glass rounded-[2.5rem] border border-white/5 p-8 relative overflow-hidden bg-black/40 min-h-[550px]">
                    <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-[#a88c5a]/5 to-transparent opacity-50 pointer-events-none"></div>
                    
                    <div class="relative z-10">
                        <span class="text-[10px] font-black tracking-[0.2em] uppercase text-[#a88c5a] mb-6 block">01 / Choose Category</span>
                        
                        <div class="flex flex-col gap-3 mb-8">
                            <button type="button" id="demo-prod-battery" class="demo-prod-btn active flex items-center gap-4 p-4 rounded-2xl border border-[#a88c5a]/40 bg-[#a88c5a]/10 text-white transition-all text-left group">
                                <span class="text-3xl filter drop-shadow-[0_0_10px_rgba(168,140,90,0.3)] transition-transform group-hover:scale-110">🔋</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white group-hover:text-[#a88c5a] transition-colors"><%= t.batteryName || 'Li-Ion Battery' %></span>
                                    <span class="text-[9px] text-white/40 uppercase tracking-widest mt-0.5">ESPR 2027 // Wave 1 Standard</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-textile" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">🧥</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.textileName || 'Wool Coat (ESPR)' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">ESPR 2027 // Wave 1 Textiles</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-watch" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">⌚</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.watchName || 'Precision Chronograph' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">ESPR 2028 // Wave 2 Luxury Goods</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-lifecycle" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">🔄</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.lifecycleName || 'End-to-End Lifecycle' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">8-Step Factory-to-Cradle Loop</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-customs" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">🛃</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.customsName || 'Zoll-Überprüfung (UNTP)' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">UNTP / EU Border Transit Gateway</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-resell" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">🤝</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.resellName || 'Eigentümerwechsel & Resell' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">Automated Secondary Royalties</span>
                                </div>
                            </button>

                            <button type="button" id="demo-prod-recycling" class="demo-prod-btn flex items-center gap-4 p-4 rounded-2xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-left group">
                                <span class="text-3xl transition-transform group-hover:scale-110">♻️</span>
                                <div class="flex flex-col">
                                    <span class="text-xs uppercase tracking-wider font-extrabold text-white/70 group-hover:text-white transition-colors"><%= t.recyclingName || 'Recycling & Pfand-Auszahlung' %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-widest mt-0.5">Circular Closed-Loop Refund</span>
                                </div>
                            </button>
                        </div>
                    </div>

                    <div class="relative z-10">
                        <span class="text-[10px] font-black tracking-[0.2em] uppercase text-[#a88c5a] mb-3 block">02 / Execute Action</span>
                        <button id="demo-scan-btn" type="button" class="w-full bg-gradient-to-r from-[#a88c5a] to-[#c7aa74] hover:from-[#bfa573] hover:to-[#dec495] text-black font-extrabold py-4 rounded-2xl text-[11px] uppercase tracking-[0.2em] transition-all hover:scale-[1.01] active:scale-95 shadow-[0_0_30px_rgba(168,140,90,0.15)] flex justify-center items-center gap-3">
                            <svg class="animate-pulse" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v1"/><path d="M12 9h10v12H12z"/></svg>
                            <span><%= t.scanBtn || 'Simulate NXP secure NFC Scan' %></span>
                        </button>
                    </div>
                </div>

                <!-- Right Simulated Terminal Display -->
                <div class="lg:col-span-7 flex flex-col justify-between border border-white/10 rounded-[2.5rem] p-6 text-left relative overflow-hidden bg-black/85 shadow-2xl min-h-[550px]">
                    <div class="absolute inset-0 bg-radial-at-t from-white/[0.02] to-transparent pointer-events-none"></div>
                    
                    <!-- Header panel of console -->
                    <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-4 relative z-10">
                        <div class="flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500/80 shadow-[0_0_8px_rgba(239,68,68,0.5)]"></span>
                            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80 shadow-[0_0_8px_rgba(234,179,8,0.5)]"></span>
                            <span class="w-2.5 h-2.5 rounded-full bg-green-500/80 shadow-[0_0_8px_rgba(34,197,94,0.5)]"></span>
                            <span class="text-[9px] font-mono text-white/30 uppercase tracking-widest ml-3">v-ledger-core-node // active</span>
                        </div>
                        <div class="flex items-center gap-1.5 px-3 py-1 rounded-full border border-green-500/20 bg-green-500/5 text-green-400 text-[8px] uppercase tracking-widest font-mono">
                            <span class="relative flex h-1.5 w-1.5">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
                            </span>
                            DUISBURG GATEWAY
                        </div>
                    </div>

                    <!-- Terminal Output Console -->
                    <div id="demo-terminal-log" class="font-mono text-[10px] leading-relaxed text-[#e0cfb3] flex-1 overflow-y-auto pr-2 space-y-2 select-text custom-scrollbar relative z-10">
                        <span class="text-white/30 block mt-2">Console initialized. Select a category on the left and click "EXECUTE CRYPTOGRAPHIC NXP SCAN" to verify hardware-backed digital product twins directly on Base Layer-2 ledger.</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Flying Article Stack: Build 21.0 (The Epic 6-Part Story) -->
        <div id="article-stack" class="article-stack-section mb-32">
            <div class="sticky-reveal-wrapper article-stack-wrapper">
                
                <!-- Slide 1: SaaS platform -->
                <div class="article-row-stack reveal-on-scroll" data-index="0">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/slider-1.png" alt="SaaS Scanning Platform - ESPR Compliance Gateway Duisburg" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                01 / The Foundation
                            </div>
                            <h3 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%- t.s1h %>
                            </h3>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.s1p %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 2: Passive Income -->
                <div class="article-row-stack reveal-on-scroll" data-index="1">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/slider-2.png" alt="Royalty Revenue Stream - Passive Income through Tokenized Export" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                02 / The Revenue Model
                            </div>
                            <h3 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%- t.s2h %>
                            </h3>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.s2p %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 3: Wallets (AA) -->
                <div class="article-row-stack reveal-on-scroll" data-index="2">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-1.png" alt="Invisible Wallets - Seamless Account Abstraction for B2B Export" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                03 / User Experience
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p1h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p1d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 4: Real World Assets -->
                <div class="article-row-stack reveal-on-scroll" data-index="3">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-2.png" alt="Tokenized Exports - Digital Twins on Blockchain for Battery Passports" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                04 / Digital Twins
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p2h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p2d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 5: The Ledger -->
                <div class="article-row-stack reveal-on-scroll" data-index="4">
                    <div class="article-row max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-3.png" alt="High Performance Ledger - Base L2 Secure Blockchain Gateway" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                05 / The Digital Backbone
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p3h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p3d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Slide 6: Physical Security -->
                <div class="article-row-stack reveal-on-scroll" data-index="5">
                    <div class="article-row article-row-reverse max-w-7xl mx-auto px-6 md:px-12">
                        <div class="article-image-container flex-1.2 relative">
                            <div class="article-glow"></div>
                            <img src="/assets/tech-wall-4.png" alt="NXP Secure Element - Unforgeable Identity for German Export Products" class="w-full h-auto">
                        </div>
                        <div class="article-text-container flex-1 text-right md:text-left">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-8">
                                06 / Physical Trust
                            </div>
                            <h4 class="text-2xl md:text-4xl font-black mb-8 tracking-tight uppercase leading-tight text-white">
                                <%= t.p4h %>
                            </h4>
                            <p class="text-xl text-white/40 leading-relaxed font-medium">
                                <%= t.p4d %>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Progress UI -->
                <div class="reveal-progress-container !left-[8%]">
                    <div id="stack-progress-fill" class="reveal-progress-fill"></div>
                </div>
            </div>
        </div>

        <!-- Section Transition Padding -->
        <div class="h-24"></div>

        <div class="mb-48 text-center max-w-4xl mx-auto px-6">
            <p id="quote-text" class="text-2xl md:text-3xl font-medium leading-relaxed mb-6 text-white/80 italic">
                <%= t.quote %>
            </p>
            <p id="quote-sub" class="section-header"><%= t.quotesub %></p>
        </div>

        <!-- FAQ Section: Build 3.0 Apple Glass Accordion -->
        <section id="faq" class="max-w-4xl mx-auto px-6 mb-48">
            <h2 class="text-3xl md:text-4xl font-black mb-16 tracking-tight uppercase text-center">
                <%= t.faqTitle %>
            </h2>
            <div class="space-y-4">
                <% t.faqs.forEach((faq, index) => { %>
                <div class="faq-item apple-glass rounded-[2rem] border border-white/5 overflow-hidden transition-all duration-500 hover:border-[#a88c5a]/30">
                    <button class="faq-trigger w-full text-left px-8 py-7 flex justify-between items-center group">
                        <span class="text-lg md:text-xl font-bold text-white/90 group-hover:text-white transition-colors uppercase tracking-tight">
                            <%= faq.q %>
                        </span>
                        <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-hover:border-[#a88c5a]/50 transition-all transform group-hover:rotate-180">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#a88c5a]"><path d="M6 9l6 6 6-6"></path></svg>
                        </div>
                    </button>
                    <div class="faq-content max-h-0 overflow-hidden transition-all duration-700 ease-in-out bg-white/[0.02]">
                        <div class="px-8 pb-8 pt-2 text-white/50 text-lg leading-relaxed font-medium">
                            <%= faq.a %>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </section>

        <!-- Strategy Button at Bottom -->
        <div class="flex justify-center mt-48 mb-24">
            <button id="v2-bottom-trigger" class="pill-btn pill-btn-vault px-20 py-6 text-lg uppercase tracking-widest font-black group">
                <span class="relative z-10"><%= t.contact %></span>
                <div class="btn-slide"></div>
            </button>
        </div>
    </main>

    <%- include('partials/footer', { t }) %>
    <%- include('partials/cookie_consent', { t }) %>
    <script src="/js/cookie-consent.js?v=20.0" defer></script>
</body>
</html>
