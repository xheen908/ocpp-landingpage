<!DOCTYPE html>
<html lang="<%= t.lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t.metaTitle %></title>
    <meta name="description" content="<%= t.metaDesc %>">
    
    <!-- SEO: Canonical and Hreflang Clusters (Global AI Indexing) -->
    <link rel="canonical" href="https://ocpp-labs.com/<%= t.lang %>/">
    <link rel="alternate" hreflang="de-de" href="https://ocpp-labs.com/de-de/">
    <link rel="alternate" hreflang="en-us" href="https://ocpp-labs.com/en-us/">
    <link rel="alternate" hreflang="vi-vn" href="https://ocpp-labs.com/vi-vn/">
    <link rel="alternate" hreflang="th-th" href="https://ocpp-labs.com/th-th/">
    <link rel="alternate" hreflang="zh-cn" href="https://ocpp-labs.com/zh-cn/">
    <link rel="alternate" hreflang="zh-tw" href="https://ocpp-labs.com/zh-tw/">
    <link rel="alternate" hreflang="x-default" href="https://ocpp-labs.com/en-us/">

    <!-- JSON-LD Structured Data (Machine Readability & AI Agents) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://ocpp-labs.com/#organization",
          "name": "OCPP Solution UG",
          "url": "https://ocpp-labs.com",
          "logo": "https://ocpp-labs.com/assets/logo.png",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Duisburg",
            "addressCountry": "DE"
          }
        },
        {
          "@type": "TechArticle",
          "headline": "OCPP-Labs: Die Zukunft der ESPR-Compliance (DPP)",
          "description": "<%= t.metaDesc %>",
          "author": { "@id": "https://ocpp-labs.com/#organization" },
          "keywords": ["Digital Product Passport", "ESPR 2027", "Battery Passport", "NTAG 424 DNA", "Base L2 Blockchain"]
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            <% t.faqs.forEach((faq, index) => { %>
            {
              "@type": "Question",
              "name": "<%= faq.q %>",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "<%= faq.a %>"
              }
            }<%= index < t.faqs.length - 1 ? ',' : '' %>
            <% }); %>
          ]
        }
      ]
    }
    </script>

    <!-- External Resources -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <link rel="stylesheet" href="/css/style.css?v=13.3-SSR">

    <!-- SES-Proof Scripts (Programmatic Only) -->
    <script src="/js/main.js?v=13.3-SSR" defer></script>
</head>
<body class="selection:bg-white/10">
    <div class="mesh-bg"></div>

    <%- include('partials/header', { t }) %>

    <main class="max-w-6xl mx-auto px-6 py-20 md:py-32">
        <!-- Hero Section: Build 8.1 Split-Screen -->
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-32">
            <div class="text-left animate-fade-in">
                <div id="hero-badge" class="badge-market"><%= t.badge %></div>
                <h1 id="h1-text" class="text-4xl md:text-[4.2rem] font-extrabold mb-8 leading-[1.05] tracking-[-0.04em]">
                    <%- t.h1 %>
                </h1>
                <p id="sub-text" class="text-lg md:text-xl text-white/50 max-w-xl mb-12 font-medium leading-relaxed">
                    <%= t.sub %>
                </p>
                
                <div class="flex flex-wrap gap-6">
                    <button id="v2-hero-trigger" class="pill-btn pill-btn-primary uppercase tracking-widest">
                        <%= t.cta %>
                    </button>
                    <div class="flex items-center gap-4 px-6 py-2 rounded-full border border-white/5 bg-white/2 overflow-hidden backdrop-blur-sm">
                        <span class="text-[9px] font-bold tracking-widest text-[#a88c5a] uppercase">ESPR 2027 Ready</span>
                    </div>
                </div>
            </div>
            
            <div class="relative group animate-float">
                <div class="absolute -inset-4 bg-gradient-to-tr from-[#a88c5a]/20 to-transparent blur-3xl opacity-30 group-hover:opacity-50 transition-opacity"></div>
                <div class="relative apple-glass rounded-[3rem] overflow-hidden border border-white/10 shadow-2xl">
                    <img src="/assets/hero-elite.png" alt="High-Value Goods with Digital Passport" class="w-full aspect-[4/5] object-cover mix-blend-lighten opacity-90 transition-transform duration-1000 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                    <div class="absolute bottom-8 left-8 right-8 p-6 apple-glass-dark rounded-2xl border-white/5 translate-y-4 group-hover:translate-y-0 transition-transform">
                        <div class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#a88c5a] mb-1">Asset Security</div>
                        <div class="text-sm font-medium text-white/70">Batteries, Textiles & Luxury Exports</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tech Authority Bar -->
        <div class="flex flex-wrap justify-start gap-12 mb-48 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700">
            <div class="flex items-center gap-3">
                <span class="text-[10px] font-bold tracking-[0.2em] uppercase">Base L2 Infrastructure</span>
            </div>
            <div class="flex items-center gap-3 border-l border-white/10 pl-12">
                <span class="text-[10px] font-bold tracking-[0.2em] uppercase">NXP Secure Identity</span>
            </div>
            <div class="flex items-center gap-3 border-l border-white/10 pl-12">
                <span class="text-[10px] font-bold tracking-[0.2em] uppercase">NTAG 424 DNA Integrated</span>
            </div>
        </div>

        <!-- Strategy Slider -->
        <div class="mb-48">
            <div class="swiper mySwiper">
                <div class="swiper-wrapper">
                    <div class="swiper-slide" style="background-image: url('/assets/slider-1.png')">
                        <div class="swiper-overlay">
                            <span class="section-header" style="color: #a88c5a;">SaaS Platform</span>
                            <h3 id="slide1-h" class="text-4xl font-bold mb-4"><%= t.s1h %></h3>
                            <p id="slide1-p" class="text-lg text-white/50 max-w-xl"><%= t.s1p %></p>
                        </div>
                    </div>
                    <div class="swiper-slide" style="background-image: url('/assets/slider-2.png')">
                        <div class="swiper-overlay">
                            <span class="section-header" style="color: #a88c5a;">Passive Income</span>
                            <h3 id="slide2-h" class="text-4xl font-bold mb-4"><%= t.s2h %></h3>
                            <p id="slide2-p" class="text-lg text-white/50 max-w-xl"><%= t.s2p %></p>
                        </div>
                    </div>
                </div>
                <div class="swiper-pagination"></div>
            </div>
        </div>

        <%- include('partials/features', { t }) %>

        <!-- Revenue Calculator Section -->
        <div class="mb-48 p-12 md:p-20 apple-glass rounded-[4rem] relative overflow-hidden">
            <div class="flex flex-col md:flex-row gap-16 items-center">
                <div class="flex-1 text-left">
                    <div class="section-header">Revenue Stream Mastery</div>
                    <h2 class="text-4xl font-bold mb-6"><%= t.calcH %></h2>
                    <p class="text-lg text-white/40 mb-10 leading-relaxed font-medium">
                        Verwandeln Sie Compliance in Profit. Rechnen Sie aus, wie viel passives Einkommen Ihr Exportvolumen generieren kann.
                    </p>
                </div>
                <div class="flex-1 w-full flex flex-col gap-8">
                    <div class="calculator-field">
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-white/30 mb-3"><%= t.calcV %></label>
                        <input type="number" id="calc-volume" value="100000" class="w-full text-2xl font-bold bg-white/5 border-white/10 rounded-2xl p-6">
                    </div>
                    <div class="grid grid-cols-2 gap-8">
                        <div class="calculator-field">
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-white/30 mb-3"><%= t.calcR %></label>
                            <input type="number" id="calc-rate" value="20" class="w-full text-2xl font-bold bg-white/5 border-white/10 rounded-2xl p-6">
                        </div>
                        <div class="calculator-field">
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-white/30 mb-3"><%= t.calcF %></label>
                            <input type="number" id="calc-fee" value="1.00" step="0.1" class="w-full text-2xl font-bold bg-white/5 border-white/10 rounded-2xl p-6">
                        </div>
                    </div>
                    <div class="mt-8 p-8 bg-white/5 rounded-[2rem] border border-white/10 text-center">
                        <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#a88c5a] mb-2"><%= t.calcP %></div>
                        <div id="calc-result" class="text-5xl font-extrabold gradient-text">20.000 €</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-48 text-center max-w-4xl mx-auto">
            <p id="quote-text" class="text-2xl md:text-3xl font-medium leading-relaxed mb-6 text-white/80 italic">
                <%= t.quote %>
            </p>
            <p id="quote-sub" class="section-header"><%= t.quotesub %></p>
        </div>

        <!-- Strategy Button at Bottom -->
        <div class="flex justify-center mt-48 mb-24">
            <button id="v2-bottom-trigger" class="pill-btn pill-btn-primary px-20 py-6 text-lg uppercase tracking-widest transition-all">
                <%= t.contact %>
            </button>
        </div>

        <%- include('partials/form', { t }) %>
    </main>

    <%- include('partials/footer', { t }) %>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
</body>
</html>
