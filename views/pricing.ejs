<!DOCTYPE html>
<html lang="<%= t.lang %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/coin-icon.png">
    <title>
        <%= t.lang==='de-de' ? 'Preise & Abonnements' : 'Pricing & Subscriptions' %> | V-LEDGER
    </title>
    <meta name="description"
        content="<%= t.lang === 'de-de' ? 'Flexibles Tier-System zur Skalierung vom ersten Prototyp bis zur weltweiten Fertigungslinie.' : 'Flexible tier system to scale from initial prototype to enterprise global manufacturing lines.' %>">
    <meta name="robots" content="index, follow">

    <!-- Hreflang Clusters -->
    <link rel="alternate" hreflang="de-de" href="https://V-Ledger.com/de-de/pricing">
    <link rel="alternate" hreflang="en-us" href="https://V-Ledger.com/en-us/pricing">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
    <!-- Flag Icons for Header -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.0.0/css/flag-icons.min.css" />
    <link rel="stylesheet" href="/css/style.css?v=15.0">
</head>

<body class="selection:bg-[#d4af37] selection:text-black overflow-x-hidden">
    <div class="mesh-bg opacity-30"></div>

    <%- include('partials/header', { t }) %>

        <main class="max-w-6xl mx-auto px-6 py-24 md:py-32 min-h-screen relative z-10">

            <!-- Hero Section for Pricing -->
            <div class="text-center mb-20 relative animate-fade-in">
                <div
                    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-[#d4af37]/20 blur-[100px] rounded-full pointer-events-none">
                </div>
                <div
                    class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-black mb-6">
                    <%= t.lang==='de-de' ? 'Tier-System & Metering' : 'Tier System & Metering' %>
                </div>
                <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter uppercase leading-[0.9]">
                    <%= t.lang==='de-de' ? 'Preise & Abonnements' : 'Pricing & Subscriptions' %>
                </h1>
                <p class="text-xl md:text-2xl font-light text-white/70 max-w-2xl mx-auto">
                    <%= t.lang==='de-de'
                        ? 'Flexibles Metering- und Tier-System zur Skalierung vom Prototyp bis zur weltweiten Fertigungslinie.'
                        : 'Flexible metering and tier system to scale from initial prototype to enterprise global manufacturing lines.'
                        %>
                </p>
            </div>

            <!-- Tier Cards Deck (Overhauled to Balanced 3-Column Enterprise Structure) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 animate-fade-in-up"
                style="animation: fadeInUp 1s ease 0.2s forwards;">
 
                <!-- Sandbox Plan -->
                <div
                    class="apple-glass border border-white/10 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden flex flex-col justify-between group hover:border-[#a88c5a]/30 transition-all duration-500">
                    <div>
                        <div class="text-[#a88c5a] text-[10px] font-black uppercase tracking-widest mb-4">Dev Sandbox</div>
                        <h3 class="text-2xl font-black italic uppercase text-white mb-2">Sandbox</h3>
                        <p class="text-white/40 text-xs mb-6">
                            <%= t.lang==='de-de' ? 'Ideal für Entwickler zum Testen von physischen Scans, APIs und Datenstrukturen.'
                                : 'Ideal for developers to test out physical scans, core APIs, and compliance data schemas.' %>
                        </p>
                        <div class="text-3xl font-black text-white italic mb-2">€0 <span
                                class="text-sm font-normal text-white/40">/mo</span></div>
                        <div class="text-[#a88c5a] text-xs font-bold uppercase tracking-wide mb-6">
                            <%= t.lang==='de-de' ? 'Bis zu 50 aktive Pässe' : 'Up to 50 active Passports' %>
                        </div>
                        <ul class="space-y-3 mb-8">
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Voller Core API-Zugriff (Sandbox)' : 'Full core API access (Sandbox)' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Kryptographische Testschlüssel (NXP CMAC)' : 'Cryptographic test keys (NXP CMAC)' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Community & Entwickler-Support' : 'Community & developer support' %>
                            </li>
                        </ul>
                    </div>
                </div>
 
                <!-- Standard Compliance Plan -->
                <div
                    class="apple-glass border-2 border-[#a88c5a] rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden flex flex-col justify-between group transition-all duration-500">
                    <div
                        class="absolute top-0 right-0 bg-[#a88c5a] text-black font-black uppercase text-[8px] tracking-widest px-3 py-1 rounded-bl-xl">
                        Recommended</div>
                    <div>
                        <div class="text-[#a88c5a] text-[10px] font-black uppercase tracking-widest mb-4">ESPR Compliance</div>
                        <h3 class="text-2xl font-black italic uppercase text-white mb-2">Standard</h3>
                        <p class="text-white/40 text-xs mb-6">
                            <%= t.lang==='de-de' ? 'Für etablierte Hersteller zur gesetzeskonformen Umsetzung von ESPR-Standards.'
                                : 'For established manufacturers to implement fully compliant ESPR standards.' %>
                        </p>
                        <div class="text-3xl font-black text-white italic mb-2">€149 <span
                                class="text-sm font-normal text-white/40">/mo</span></div>
                        <div class="text-[#a88c5a] text-xs font-bold uppercase tracking-wide mb-6">+ €0.05 per active Passport
                        </div>
                        <ul class="space-y-3 mb-8">
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Konform nach W3C VC & AAS-Spezifikationen' : 'Fully compliant with W3C VC & AAS specs' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Sponsor-Transaktionen (Gas-Abstraktion)' : 'Sponsored transactions (Gas Abstraction)' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Kunden-Besitzrechte-Anspruch via Web-NFC' : 'Customer ownership claim via Web NFC' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Priorisierter E-Mail-Support SLA (< 24h)' : 'Prioritized email support SLA (< 24h)' %>
                            </li>
                        </ul>
                    </div>
                </div>
 
                <!-- Sovereign Node Plan -->
                <div
                    class="apple-glass border border-white/10 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden flex flex-col justify-between group hover:border-[#a88c5a]/30 transition-all duration-500">
                    <div>
                        <div class="text-[#a88c5a] text-[10px] font-black uppercase tracking-widest mb-4">Sovereign Operations</div>
                        <h3 class="text-2xl font-black italic uppercase text-white mb-2">Enterprise</h3>
                        <p class="text-white/40 text-xs mb-6">
                            <%= t.lang==='de-de' ? 'Für industriellen Großbetrieb, eigene Gas-Paymaster und souveräne Core-Nodes.'
                                : 'For large industrial operations, custom gas paymasters, and sovereign core nodes.' %>
                        </p>
                        <div class="text-3xl font-black text-white italic mb-2">Custom</div>
                        <div class="text-[#a88c5a] text-xs font-bold uppercase tracking-wide mb-6">Sovereign Tier
                        </div>
                        <ul class="space-y-3 mb-8">
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Dedizierte physische oder virtuelle Nodes' : 'Dedicated physical or virtual core nodes' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Private Cloud- oder On-Premises Option' : 'Private cloud or on-premises deployment option' %>
                            </li>
                            <li class="flex items-start gap-2 text-xs text-white/70">
                                <span class="text-[#a88c5a] font-bold">✓</span>
                                <%= t.lang==='de-de' ? 'Eigener Solutions-Architekt & 24/7 SLA' : 'Dedicated Solutions Architect & 24/7 SLA' %>
                            </li>
                        </ul>
                    </div>
                </div>
 
            </div>
 
            <!-- Pay-Per-Mint Explained -->
            <div class="w-full apple-glass border border-white/10 border-l-4 border-l-[#a88c5a] rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden mb-16 animate-fade-in-up block clear-both"
                style="animation: fadeInUp 1s ease 0.4s forwards;">
                <h2 class="text-2xl font-black italic uppercase text-white mb-4">
                    <%= t.lang==='de-de' ? 'Pay-Per-Passport Erklärt' : 'Pay-Per-Passport Explained' %>
                </h2>
                <p class="text-sm text-white/60 mb-8 max-w-4xl leading-relaxed">
                    <%= t.lang==='de-de'
                        ? 'Zusätzlich zur monatlichen Grundgebühr nutzt unsere Infrastruktur Smart Contracts, um zirkuläre Produktpass-Daten manipulationssicher On-Chain zu speichern. Jeder im V-Ledger-Ökosystem registrierte digitale Zwilling erzeugt eine geringe Nutzungsgebühr für die gasfreie Account Abstraction-Transaktion und die Metadaten-Verifizierung.'
                        : 'Besides the monthly base subscription fee, our infrastructure leverages smart contracts to secure circular product deposits on-chain. Each digital twin registered in the V-Ledger ecosystem incurs a small usage fee to sponsor the gas-less Account Abstraction transaction and metadata verification on the blockchain.'
                        %>
                </p>
 
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left text-sm text-white/70">
                        <thead class="text-[10px] text-white/40 uppercase tracking-widest bg-white/5">
                            <tr>
                                <th class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Volumen-Stufe' : 'Volume Tier' %>
                                </th>
                                <th class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Gebühr pro Pass' : 'Fee per Passport' %>
                                </th>
                                <th class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Enthaltene Transaktionen' : 'Included Transactions' %>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <tr class="hover:bg-white/2 transition-colors">
                                <td class="px-6 py-4 font-black text-white uppercase italic">Sandbox (Free)</td>
                                <td class="px-6 py-4">€0</td>
                                <td class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Bis zu 50 aktive digitale Pässe' : 'Up to 50 active passports' %>
                                </td>
                            </tr>
                            <tr class="hover:bg-white/2 transition-colors">
                                <td class="px-6 py-4 font-black text-white uppercase italic">Standard Compliance</td>
                                <td class="px-6 py-4">€0.05</td>
                                <td class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Sponsor-Transaktionen inklusive' : 'Sponsored Gas-Abstraction transactions included' %>
                                </td>
                            </tr>
                            <tr class="hover:bg-white/2 transition-colors">
                                <td class="px-6 py-4 font-black text-white uppercase italic">Sovereign Node / Enterprise</td>
                                <td class="px-6 py-4">Custom (Bulk pricing)</td>
                                <td class="px-6 py-4">
                                    <%= t.lang==='de-de' ? 'Dedizierte Nodes & unbegrenzter Batch-Durchsatz' : 'Dedicated Core Nodes & unlimited batch throughput' %>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>

        <%- include('partials/footer', { t }) %>

            <style>
                @keyframes fadeInUp {
                    from {
                        opacity: 0;
                        transform: translateY(40px);
                    }

                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }

                .animate-fade-in {
                    animation: fadeInUp 0.8s ease forwards;
                }
            </style>
            <script src="/js/main.js?v=15.7"></script>
</body>

</html>