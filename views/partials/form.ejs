<div id="contact-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/90 backdrop-blur-3xl transition-opacity duration-500">
    <div class="relative w-full max-w-5xl p-6 md:p-10 apple-glass rounded-[2.5rem] border border-white/10 shadow-[0_0_80px_rgba(168,140,90,0.15)] text-center transform scale-95 transition-transform duration-500 overflow-hidden">
        
        <!-- Animated Background Glow inside Modal -->
        <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-[#a88c5a]/10 to-transparent opacity-50 pointer-events-none"></div>

        <!-- Close Button (Programmatic event listener attached in main.js) -->
        <button id="modal-close" type="button" class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center rounded-full bg-white/5 hover:bg-white/10 border border-white/5 text-white/50 hover:text-white transition-all duration-300 z-50">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 1l12 12M13 1L1 13"/></svg>
        </button>
        
        <div class="relative z-10 grid md:grid-cols-12 gap-8 items-stretch">
            
            <!-- Left Column: Lead Capture Form (Strategic Partner Request) -->
            <div class="md:col-span-6 flex flex-col justify-between text-left">
                <div>
                    <div id="modal-header" class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#a88c5a]/30 bg-[#a88c5a]/10 text-[#a88c5a] text-[10px] uppercase tracking-widest font-bold mb-4">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                        <%= t.mHeader || 'Strategic Partner Audit' %>
                    </div>
                    
                    <h2 id="footer-h2" class="text-2xl md:text-4xl font-extrabold mb-3 tracking-tight text-white"><%= t.footerH2 %></h2>
                    <p id="footer-p" class="text-white/40 text-xs md:text-sm font-medium mb-6 max-w-md leading-relaxed"><%= t.footerP %></p>
                </div>
                
                <form id="lead-form" class="flex flex-col gap-4 text-left relative">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div class="relative group">
                            <input type="text" name="name" placeholder="Brand / Entity" required class="w-full !bg-black/50 !border !border-white/10 !rounded-xl !p-3.5 !pl-11 text-xs text-white focus:!border-[#a88c5a] focus:!ring-1 focus:!ring-[#a88c5a] transition-all peer placeholder-transparent">
                            <label class="absolute left-11 top-[0.9rem] text-xs text-white/30 transition-all peer-focus:-top-2 peer-focus:text-[9px] peer-focus:text-[#a88c5a] peer-valid:-top-2 peer-valid:text-[9px] peer-valid:text-white/50 bg-black px-1 rounded-sm pointer-events-none">Brand / Entity</label>
                            <svg class="absolute left-4 top-[1rem] text-white/20 group-focus-within:text-[#a88c5a] transition-colors pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div class="relative group">
                            <input type="email" name="email" placeholder="Corporate Email" required class="w-full !bg-black/50 !border !border-white/10 !rounded-xl !p-3.5 !pl-11 text-xs text-white focus:!border-[#a88c5a] focus:!ring-1 focus:!ring-[#a88c5a] transition-all peer placeholder-transparent">
                            <label class="absolute left-11 top-[0.9rem] text-xs text-white/30 transition-all peer-focus:-top-2 peer-focus:text-[9px] peer-focus:text-[#a88c5a] peer-valid:-top-2 peer-valid:text-[9px] peer-valid:text-white/50 bg-black px-1 rounded-sm pointer-events-none">Corporate Email</label>
                            <svg class="absolute left-4 top-[1rem] text-white/20 group-focus-within:text-[#a88c5a] transition-colors pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </div>
                    </div>
                    
                    <div class="relative group">
                        <textarea name="message" rows="3" placeholder="Project Details" required class="w-full !bg-black/50 !border !border-white/10 !rounded-xl !p-3.5 text-xs text-white focus:!border-[#a88c5a] focus:!ring-1 focus:!ring-[#a88c5a] transition-all peer placeholder-transparent resize-none"></textarea>
                        <label class="absolute left-4 top-[0.9rem] text-xs text-white/30 transition-all peer-focus:-top-2 peer-focus:text-[9px] peer-focus:text-[#a88c5a] peer-valid:-top-2 peer-valid:text-[9px] peer-valid:text-white/50 bg-black px-1 rounded-sm pointer-events-none">Pilot Scope / Compliance Gaps...</label>
                    </div>

                    <div class="flex items-start gap-3 px-1 mt-1">
                        <div class="relative flex items-center justify-center mt-0.5">
                            <input type="checkbox" id="privacy-consent" name="consent" required class="peer appearance-none w-4 h-4 border border-white/20 rounded cursor-pointer checked:bg-[#a88c5a] checked:border-[#a88c5a] transition-colors">
                            <svg class="absolute pointer-events-none opacity-0 peer-checked:opacity-100 w-2.5 h-2.5 text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        </div>
                        <label for="privacy-consent" class="text-white/40 text-[9px] tracking-widest uppercase cursor-pointer leading-tight flex-1 hover:text-white/60 transition-colors">
                            <%= t.legal.agree %> <a href="/<%= t.lang %>/legal/privacy" target="_blank" class="text-white/70 hover:text-[#a88c5a] underline underline-offset-4 transition-colors"><%= t.legal.privacy %></a>
                        </label>
                    </div>

                    <div class="mt-2">
                        <button id="contact-button" type="submit" class="w-full bg-gradient-to-r from-[#a88c5a] to-[#c7aa74] hover:from-[#bfa573] hover:to-[#dec495] text-black font-extrabold py-3.5 rounded-xl text-[10px] uppercase tracking-[0.2em] transition-all hover:scale-[1.01] active:scale-95 shadow-[0_0_20px_rgba(168,140,90,0.2)] flex justify-center items-center gap-3">
                            <span><%= t.contact %></span>
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                        </button>
                    </div>
                    <!-- Status is placed outside of normal flow to stop jumping -->
                    <div id="form-status" class="absolute -bottom-7 w-full text-center text-[10px] font-bold tracking-[0.2em] uppercase hidden transition-all"></div>
                </form>
            </div>

            <!-- Right Column: Interactive DPP Live Simulator -->
            <div class="md:col-span-6 flex flex-col justify-between border border-white/5 rounded-[2rem] p-6 text-left relative overflow-hidden bg-black/60 min-h-[420px]">
                <div>
                    <h3 class="text-base font-bold text-white mb-1 flex items-center gap-2">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-yellow-500"></span>
                        </span>
                        <%= t.demoTitle || 'Interactive DPP Sandbox' %>
                    </h3>
                    <p class="text-white/40 text-[10px] uppercase tracking-wider mb-4"><%= t.demoDesc || 'Select a category & simulate an NXP scan:' %></p>

                    <!-- Product Selectors -->
                    <div class="grid grid-cols-3 gap-2 mb-4">
                        <button type="button" id="demo-prod-battery" class="demo-prod-btn active flex flex-col items-center gap-1.5 p-2.5 rounded-xl border border-[#a88c5a]/40 bg-[#a88c5a]/10 text-white transition-all text-center">
                            <span class="text-xl">🔋</span>
                            <span class="text-[9px] uppercase tracking-wider font-extrabold line-clamp-1"><%= t.batteryName || 'Battery' %></span>
                        </button>
                        <button type="button" id="demo-prod-textile" class="demo-prod-btn flex flex-col items-center gap-1.5 p-2.5 rounded-xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-center">
                            <span class="text-xl">🧥</span>
                            <span class="text-[9px] uppercase tracking-wider font-extrabold line-clamp-1"><%= t.textileName || 'Textile' %></span>
                        </button>
                        <button type="button" id="demo-prod-watch" class="demo-prod-btn flex flex-col items-center gap-1.5 p-2.5 rounded-xl border border-white/5 bg-white/5 text-white/50 hover:text-white transition-all text-center">
                            <span class="text-xl">⌚</span>
                            <span class="text-[9px] uppercase tracking-wider font-extrabold line-clamp-1"><%= t.watchName || 'Chronograph' %></span>
                        </button>
                    </div>

                    <!-- Terminal Console Display -->
                    <div class="relative w-full bg-black/90 border border-white/10 rounded-xl p-4 font-mono text-[9px] leading-relaxed text-[#a88c5a] overflow-y-auto h-[180px] shadow-inner mb-4">
                        <div class="absolute top-2 right-2 flex items-center gap-1.5 opacity-40 z-10">
                            <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                            <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                        </div>
                        <div id="demo-terminal-log" class="space-y-1.5 text-[#e0cfb3]">
                            <span class="text-white/40">Console ready. Select a product above & press scan to execute real-time on-chain decryption & DPP generation.</span>
                        </div>
                    </div>
                </div>

                <!-- Action Scan Button -->
                <div>
                    <button id="demo-scan-btn" type="button" class="w-full bg-[#a88c5a]/10 hover:bg-[#a88c5a]/20 border border-[#a88c5a]/30 text-[#a88c5a] hover:text-white font-extrabold py-3 rounded-xl text-[9px] uppercase tracking-[0.15em] transition-all flex justify-center items-center gap-2">
                        <svg class="animate-pulse text-[#a88c5a]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v1"/><path d="M12 9h10v12H12z"/></svg>
                        <span><%= t.scanBtn || 'Simulate NXP secure NFC Scan' %></span>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>
