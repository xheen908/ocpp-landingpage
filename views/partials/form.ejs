<div id="contact-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-6 bg-black/80 backdrop-blur-3xl transition-opacity duration-500">
    <div class="relative w-full max-w-2xl p-16 apple-glass rounded-[4rem] text-center transform scale-95 transition-transform duration-500 shadow-2xl">
        <!-- Close Button (Programmatic event listener attached in main.js) -->
        <button id="modal-close" type="button" class="absolute top-8 right-12 text-white/40 hover:text-white transition-colors text-3xl font-light">×</button>
        
        <div id="modal-header" class="section-header mb-4"><%= t.mHeader %></div>
        <h2 id="footer-h2" class="text-5xl font-bold mb-6"><%= t.footerH2 %></h2>
        <p id="footer-p" class="text-white/40 text-lg font-medium mb-12"><%= t.footerP %></p>
        
        <form id="lead-form" class="flex flex-col gap-6">
            <div class="grid md:grid-cols-2 gap-6">
                <input type="text" name="name" placeholder="Brand / Entity" required class="w-full">
                <input type="email" name="email" placeholder="Corporate Email" required class="w-full">
            </div>
            <textarea name="message" rows="4" placeholder="Your requirements..." required class="w-full"></textarea>
            <div class="flex items-center gap-3 text-left px-4">
                <input type="checkbox" id="privacy-consent" name="consent" required class="w-5 h-5 accent-[#a88c5a] cursor-pointer">
                <label for="privacy-consent" class="text-white/40 text-[10px] tracking-widest uppercase cursor-pointer leading-tight">
                    <%= t.legal.agree %> <a href="/<%= t.lang %>/legal/privacy" target="_blank" class="text-white/60 hover:text-white underline transition-colors"><%= t.legal.privacy %></a>
                </label>
            </div>
            <div class="flex justify-center mt-4">
                <button id="contact-button" type="submit" class="pill-btn pill-btn-primary w-full md:w-auto px-20 text-sm uppercase tracking-widest transition-all">
                    <%= t.contact %>
                </button>
            </div>
            <div id="form-status" class="mt-4 text-sm font-bold tracking-widest uppercase text-white/40 hidden">Sending...</div>
        </form>
    </div>
</div>
