<footer class="py-6 px-8 border-t border-white/5 text-center flex flex-col md:flex-row justify-between items-center gap-4 text-white/30 text-[10px] tracking-widest uppercase mt-8 md:mt-12 w-full">
    <div id="copyright" class="order-2 md:order-1 opacity-70">
        <%- t.copy %>
    </div>

    <div class="flex flex-wrap justify-center gap-6 font-bold tracking-[0.2em] order-1 md:order-2">
        <a href="/<%= t.lang %>/about" class="hover:text-[#a88c5a] transition-colors"><%= t.aboutUs?.nav || 'About Us' %></a>
        <a href="/<%= t.lang %>/#faq" class="hover:text-[#a88c5a] transition-colors"><%= t.faqNav %></a>
        <a href="https://docs.v-ledger.com/" target="_blank" rel="noreferrer" class="hover:text-[#a88c5a] transition-colors"><%= t.lang === 'de-de' ? 'Dokumentation' : 'Documentation' %></a>
        <a href="/<%= t.lang %>/legal/imprint" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.imprint %></a>
        <a href="/<%= t.lang %>/legal/privacy" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.privacy %></a>
        <a href="/<%= t.lang %>/legal/terms" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.terms %></a>
    </div>

    <div class="order-3 flex items-center gap-3 opacity-50 hover:opacity-100 transition-opacity duration-700 mt-4 md:mt-0">
        <div class="w-12 h-12 rounded-full overflow-hidden shrink-0 shadow-lg border border-white/10 flex items-center justify-center filter grayscale hover:grayscale-0 transition-all">
            <img src="/assets/german-seal.png" alt="German Engineering" class="w-full h-full object-cover scale-150">
        </div>
        <div class="text-left">
            <div class="text-[7px] font-black tracking-widest text-[#a88c5a]">ENGINEERED IN</div>
            <div class="text-[9px] font-bold text-white/60">DUISBURG, GERMANY</div>
        </div>
    </div>
</footer>

<%- include('form', { t }) %>
