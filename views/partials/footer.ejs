<footer class="fixed bottom-0 left-0 right-0 z-[50] py-3 px-6 md:px-8 border-t border-white/10 text-center flex flex-col md:flex-row justify-between items-center gap-3 md:gap-4 text-white/40 text-[9px] md:text-[10px] tracking-widest uppercase w-full bg-[#050505]/80 backdrop-blur-2xl shadow-[0_-10px_40px_rgba(0,0,0,0.6)]">
    <div id="copyright" class="order-2 md:order-1 opacity-70 text-[8px] md:text-[10px]">
        <%- t.copy %>
    </div>

    <div class="flex flex-wrap justify-center gap-x-5 gap-y-2 font-bold tracking-[0.2em] order-1 md:order-2">
        <a href="/<%= t.lang %>/about" class="hover:text-[#a88c5a] transition-colors"><%= t.aboutUs?.nav || 'About Us' %></a>
        <a href="/<%= t.lang %>/#faq" class="hover:text-[#a88c5a] transition-colors"><%= t.faqNav %></a>
        <a href="/<%= t.lang %>/legal/imprint" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.imprint %></a>
        <a href="/<%= t.lang %>/legal/privacy" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.privacy %></a>
        <a href="/<%= t.lang %>/legal/terms" class="hover:text-[#a88c5a] transition-colors"><%= t.legal.terms %></a>
    </div>

    <div class="hidden md:flex order-3 items-center gap-3 opacity-50 hover:opacity-100 transition-opacity duration-700">
        <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 shadow-lg border border-white/10 flex items-center justify-center filter grayscale hover:grayscale-0 transition-all">
            <img src="/assets/german-seal.png" alt="German Engineering" class="w-full h-full object-cover scale-150">
        </div>
        <div class="text-left">
            <div class="text-[6px] font-black tracking-widest text-[#a88c5a]">ENGINEERED IN</div>
            <div class="text-[8px] font-bold text-white/60">DUISBURG, GERMANY</div>
        </div>
    </div>
</footer>

<%- include('form', { t }) %>
